# ===========================================================================
#  ستائر الياقوت — متغيّرات البيئة | Environment variables
#  انسخ هذا الملف إلى .env.local واملأ القيم من لوحة Supabase
#  Copy this file to .env.local and fill the values from your Supabase project
# ===========================================================================

# --- Supabase (Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="YOUR-ANON-PUBLIC-KEY"

# Service-role key — SERVER ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY="YOUR-SERVICE-ROLE-KEY"

# --- Brand / Contact ---
NEXT_PUBLIC_WHATSAPP_NUMBER="9647709164206"        # رقم واتساب بصيغة دولية بدون +
NEXT_PUBLIC_SITE_URL="https://alyaqoot.vercel.app" # عدّله بعد ربط الدومين
NEXT_PUBLIC_ADMIN_EMAIL="trukmenogulu@gmail.com"

# --- AI Visualizer (optional, for FUTURE paid providers; left empty = free in-browser mode) ---
